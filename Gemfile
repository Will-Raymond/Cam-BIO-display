# Local preview only — mirrors the GitHub Pages build environment.
# GitHub Pages itself builds the site server-side; this is just for
# `bundle exec jekyll serve` on your machine. Requires Ruby + Bundler.
source "https://rubygems.org"

gem "github-pages", group: :jekyll_plugins
gem "jekyll-include-cache", group: :jekyll_plugins

# Windows / macOS niceties
gem "webrick"
